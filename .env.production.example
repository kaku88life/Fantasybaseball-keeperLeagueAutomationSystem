# ===========================================
# Zeabur Backend Environment Variables
# ===========================================
# Copy this file and fill in actual values in Zeabur Dashboard

# --- Database ---
# Zeabur Volume mount path (create volume, mount to /app-data)
DATABASE_PATH=/app-data/keeper_league.db

# --- Auth ---
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# --- Yahoo OAuth ---
YAHOO_CLIENT_ID=dj0yJmk9...
YAHOO_CLIENT_SECRET=89b0...
YAHOO_LEAGUE_ID=469.l.80910
OAUTH_REDIRECT_URI=https://YOUR-BACKEND.zeabur.app/api/auth/yahoo/callback

# --- Frontend ---
FRONTEND_URL=https://YOUR-FRONTEND.zeabur.app
ALLOWED_ORIGINS=https://YOUR-FRONTEND.zeabur.app

# --- Server ---
# Zeabur usually auto-assigns PORT, but can set manually
# PORT=8002

# ===========================================
# Zeabur Frontend Environment Variables
# ===========================================
# Set in Zeabur Dashboard for the frontend service

# NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.zeabur.app
